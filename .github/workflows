name: Django Tests CI

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  test:
    runs-on: ubuntu-latest

    steps:
    - name: Pobranie kodu z repozytorium
      uses: actions/checkout@v4

    - name: Ustawienie środowiska Python 3.12
      uses: actions/setup-python@v5
      with:
        python-version: '3.12'

    - name: Instalacja bibliotek z requirements.txt
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt

    - name: Uruchomienie testów i pokrycia kodu
      run: |
        coverage run manage.py test
        coverage report